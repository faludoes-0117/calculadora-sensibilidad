---
import { games } from '../data/games';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Calculadora de Sensibilidad Gaming | Convierte tu Aim entre FPS</title>
    <meta name="description" content="Herramienta gratuita para convertir tu sensibilidad (eDPI) entre Valorant, CS2, Overwatch y más. Mantén tu memoria muscular intacta." />
  </head>
  <body>
    <main class="container">
      <header class="hero">
        <h1>Convertidor de Sensibilidad FPS</h1>
        <p>Transfiere tu configuración exacta entre juegos competitivos. Conserva tu memoria muscular, optimiza tu <strong>eDPI</strong> y no pierdas precisión al cambiar de shooter.</p>
      </header>

      <section class="grid-container">
        {games.map((origen) => (
          games.map((destino) => (
            origen.id !== destino.id && (
              <a href={`/calculadora-sensibilidad/${origen.id}-a-${destino.id}`} class="card-link">
                <article class="conversion-card">
                  <span class="game-name">{origen.name}</span>
                  <span class="arrow">➔</span>
                  <span class="game-name">{destino.name}</span>
                </article>
              </a>
            )
          ))
        ))}
      </section>
    </main>

    <style is:global>
      :root {
        --bg-color: #0b0e14;
        --card-bg: #151a23;
        --border-color: #1f2937;
        --accent: #00e5ff;
        --accent-hover: #00b8cc;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
      }
      
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-main);
        line-height: 1.5;
      }

      .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }

      .hero { text-align: center; margin-bottom: 3rem; }
      .hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1rem; color: var(--text-main); }
      .hero p { color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

      /* Grid Mobile-First */
      .grid-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 600px) { .grid-container { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 900px) { .grid-container { grid-template-columns: repeat(3, 1fr); } }

      .card-link { text-decoration: none; display: block; }
      
      .conversion-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s ease;
      }
      .conversion-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 229, 255, 0.1);
      }
      .game-name { font-weight: 600; color: var(--text-main); }
      .arrow { color: var(--accent); font-weight: bold; }

      /* Estilos del Componente Calculator.tsx */
      .calculator-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-top: 2rem;
      }
      .input-group label {
        display: block; color: var(--text-muted); margin-bottom: 0.5rem; font-size: 0.9rem;
      }
      .input-group input {
        width: 100%; padding: 1rem; background: var(--bg-color); border: 1px solid var(--border-color);
        color: var(--text-main); border-radius: 6px; font-size: 1.2rem; outline: none; transition: border 0.2s;
      }
      .input-group input:focus { border-color: var(--accent); }
      
      .result-group {
        display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem;
        padding-top: 1.5rem; border-top: 1px solid var(--border-color);
      }
      @media (min-width: 480px) {
        .result-group { flex-direction: row; justify-content: space-between; align-items: center; }
      }
      
      .result-text span { display: block; color: var(--text-muted); font-size: 0.9rem; }
      .result-text h3 { color: var(--accent); font-size: 2rem; margin: 0; line-height: 1; }
      
      .btn-copy {
        background: var(--accent); color: #000; border: none; padding: 1rem 1.5rem;
        font-weight: bold; border-radius: 6px; cursor: pointer; transition: background 0.2s;
        width: 100%;
      }
      @media (min-width: 480px) { .btn-copy { width: auto; } }
      .btn-copy:hover { background: var(--accent-hover); }
      .btn-copy.copied { background: #10b981; color: white; }
    </style>
  </body>
</html>