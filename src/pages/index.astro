---
import { games } from '../data/games';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Calculadoras de Sensibilidad Gaming</title>
    <meta name="description" content="Directorio de calculadoras exactas para convertir sensibilidad entre juegos FPS." />
  </head>
  <body style="font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px;">
    <h1>Convertidores de Sensibilidad</h1>
    <p>Selecciona tu conversión para mantener tu memoria muscular exacta.</p>
    
    <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; padding: 0;">
      {games.map((origen) => (
        games.map((destino) => (
          origen.id !== destino.id && (
            <li style="list-style: none; border: 1px solid #ddd; padding: 15px; border-radius: 8px; transition: 0.2s;">
              <a href={`/calculadora-sensibilidad/${origen.id}-a-${destino.id}`} style="text-decoration: none; color: #0070f3; font-weight: bold; display: block;">
                De {origen.name} a {destino.name}
              </a>
            </li>
          )
        ))
      ))}
    </ul>
  </body>
</html>