---
import { games } from '../data/games';
import Calculator from '../components/Calculator.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gaming Sensitivity Calculator | Convert Your Aim Between FPS</title>
    <meta name="description" content="Free tool to convert your mouse sensitivity (eDPI) between Valorant, CS2, Overwatch, and more. Keep your muscle memory intact." />
  </head>
  <body>
    <div class="lang-switcher">
      <select id="languageSelect">
        <option value="en">English</option>
        <option value="es">Español (ES)</option>
        <option value="es-la">Español (LA)</option>
        <option value="de">Deutsch</option>
        <option value="fr">Français</option>
        <option value="it">Italiano</option>
        <option value="zh">中文</option>
        <option value="ja">日本語</option>
        <option value="ru">Русский</option>
      </select>
    </div>

    <main class="container">
      <header class="hero">
        <h1 id="t-h1">FPS Sensitivity Converter</h1>
        <p id="t-desc">Transfer your exact settings between competitive games. Preserve your muscle memory, optimize your <strong>eDPI</strong>, and never lose precision when switching shooters.</p>
      </header>

      <Calculator client:load />
    </main>

    <style is:global>
      :root {
        --bg-color: #0b0e14;
        --card-bg: #151a23;
        --border-color: #1f2937;
        --accent: #00e5ff;
        --accent-hover: #00b8cc;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
      }
      
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      html {
        background-color: var(--bg-color);
        overflow-y: scroll;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        color: var(--text-main);
        line-height: 1.5;
        min-height: 100vh;
        position: relative;
      }

      .lang-switcher { position: absolute; top: 1rem; right: 1rem; }
      .lang-switcher select { background: var(--card-bg); color: var(--text-main); border: 1px solid var(--border-color); padding: 0.5rem; border-radius: 4px; outline: none; cursor: pointer; }

      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 1rem 2rem 1rem;
      }

      .hero { text-align: center; margin-bottom: 3rem; }
      .hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1rem; color: var(--text-main); }
      .hero p { color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

      /* Calculator Component CSS extracted from Preact file requirements */
      .seamless-calculator {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .selector-container {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      @media (min-width: 600px) {
        .selector-container {
          flex-direction: row;
          align-items: flex-end;
        }
      }

      .selector-box {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .selector-box label {
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .selector-box select {
        width: 100%;
        padding: 1rem;
        background-color: var(--bg-color);
        color: var(--text-main);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        font-size: 1.1rem;
        outline: none;
        cursor: pointer;
        transition: border 0.2s;
        appearance: none;
      }
      .selector-box select:focus {
        border-color: var(--accent);
      }

      .selector-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 1.5rem;
        padding-bottom: 0.8rem;
      }
      @media (max-width: 599px) {
        .selector-icon {
          transform: rotate(90deg);
          padding-bottom: 0;
        }
      }

      .calculator-layout {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      @media (min-width: 768px) {
        .calculator-layout {
          flex-direction: row;
          align-items: stretch;
        }
      }

      .side-card {
        background: var(--card-bg); 
        border: 1px solid var(--border-color); 
        border-radius: 12px; 
        padding: 2rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .result-side {
        border-color: var(--accent);
        box-shadow: 0 0 20px rgba(0, 229, 255, 0.05);
      }

      .input-group label { display: block; color: var(--text-muted); margin-bottom: 0.5rem; }
      .input-group label span { font-weight: bold; color: var(--text-main); }
      .input-group input { width: 100%; padding: 1rem; background: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-main); border-radius: 8px; font-size: 1.2rem; outline: none; transition: border 0.2s; }
      .input-group input:focus { border-color: var(--accent); }
      
      .dpi-group input { font-size: 1rem; padding: 0.8rem; }
      
      .result-text.input-like h3 {
        width: 100%; padding: 1rem; background: rgba(0, 229, 255, 0.05); border: 1px solid var(--accent); color: var(--accent); border-radius: 8px; font-size: 1.5rem; margin: 0; line-height: 1; text-align: center;
      }

      .distance-metric {
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px dashed var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .distance-metric span { color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; }
      .distance-metric p { color: var(--text-main); font-size: 1.1rem; font-weight: bold; margin: 0; }

      .btn-copy { background: var(--accent); color: #000; border: none; padding: 1rem 1.5rem; font-weight: bold; border-radius: 8px; cursor: pointer; transition: background 0.2s; width: 100%; }
      .btn-copy:hover { background: var(--accent-hover); }
      .btn-copy.mt { margin-top: 1rem; }
      .btn-copy.copied { background: #10b981; color: white; }
    </style>

    <script>
      const dictIndex = {
        en: { h1: "FPS Sensitivity Converter", desc: "Transfer your exact settings between competitive games. Preserve your muscle memory, optimize your <strong>eDPI</strong>, and never lose precision when switching shooters." },
        es: { h1: "Convertidor de Sensibilidad FPS", desc: "Transfiere tu configuración exacta entre juegos competitivos. Conserva tu memoria muscular, optimiza tu <strong>eDPI</strong> y no pierdas precisión al cambiar de shooter." },
        'es-la': { h1: "Convertidor de Sensibilidad FPS", desc: "Pasá tu configuración exacta entre juegos competitivos. Mantené tu memoria muscular, optimizá tu <strong>eDPI</strong> y no pierdas precisión al cambiar de shooter." },
        de: { h1: "FPS Empfindlichkeits-Konverter", desc: "Übertragen Sie Ihre genauen Einstellungen zwischen kompetitiven Spielen. Bewahren Sie Ihr Muskelgedächtnis, optimieren Sie Ihre <strong>eDPI</strong> und verlieren Sie beim Wechseln von Shootern nie an Präzision." },
        fr: { h1: "Convertisseur de Sensibilité FPS", desc: "Transférez vos paramètres exacts entre les jeux compétitifs. Préservez votre mémoire musculaire, optimisez votre <strong>eDPI</strong> et ne perdez jamais en précision en changeant de jeu de tir." },
        it: { h1: "Convertitore di Sensibilità FPS", desc: "Trasferisci le tue impostazioni esatte tra i giochi competitivi. Preserva la tua memoria muscolare, ottimizza il tuo <strong>eDPI</strong> e non perdere mai precisione quando cambi sparatutto." },
        zh: { h1: "FPS 灵敏度转换器", desc: "在竞技游戏之间转移您的精确设置。保留您的肌肉记忆，优化您的 <strong>eDPI</strong>，并在切换射击游戏时永不失去精度。" },
        ja: { h1: "FPS 感度コンバーター", desc: "対戦ゲーム間で正確な設定を転送します。マッスルメモリを維持し、<strong>eDPI</strong>を最適化し、シューターを切り替える際に精度を失うことはありません。" },
        ru: { h1: "Конвертер Чувствительности FPS", desc: "Переносите свои точные настройки между соревновательными играми. Сохраняйте мышечную память, оптимизируйте <strong>eDPI</strong> и никогда не теряйте точность при смене шутеров." }
      };

      const langSelect = document.getElementById('languageSelect') as HTMLSelectElement;

      function applyLanguage(lang: string) {
        const d = dictIndex[lang];
        if (!d) return;
        document.getElementById('t-h1').innerText = d.h1;
        document.getElementById('t-desc').innerHTML = d.desc;
        
        // Dispatch event for Preact components
        window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang } }));
      }

      langSelect.addEventListener('change', (e) => {
        const lang = (e.target as HTMLSelectElement).value;
        localStorage.setItem('siteLang', lang);
        applyLanguage(lang);
      });

      // Initial load
      setTimeout(() => {
        const savedLang = localStorage.getItem('siteLang') || 'en';
        langSelect.value = savedLang;
        applyLanguage(savedLang);
      }, 0);
    </script>
  </body>
</html>